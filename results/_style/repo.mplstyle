# Toll Plaza palette for this repo. Re-rendered charts pick this up.
axes.facecolor: #FFFCF2
figure.facecolor: #FFFCF2
axes.edgecolor: #1c1c1c
axes.labelcolor: #1c1c1c
axes.titlecolor: #1c1c1c
axes.titleweight: bold
xtick.color: #1c1c1c
ytick.color: #1c1c1c
grid.color: #F1E9DA
grid.alpha: 0.5
axes.grid: True
axes.spines.top: False
axes.spines.right: False
axes.prop_cycle: cycler('color', [#2E294E, #541388, #F1E9DA, #FFD400, #D90368, #04A777])
font.family: sans-serif
font.sans-serif: Helvetica, Arial, DejaVu Sans
font.size: 10
figure.titlesize: 14
figure.titleweight: bold
image.cmap: cividis
